# Backend environment example

# --- CORS ---
# Comma-separated list of allowed origins, e.g.:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
# Leave unset to allow "*" (dev only; credentials disabled).

# --- Database (XAMPP defaults shown) ---
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=soccer_analytics

# --- JWT keys (recommended for prod) ---
# Option A: provide PEM contents directly
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Option B: provide filesystem paths to PEM files
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# --- LLM ---
LLM_MODE=remote
LLM_TIMEOUT=60
REMOTE_LLM_URL=https://2a8a-34-12-240-241.ngrok-free.app/generate

